"""MCP73831 LiPo Battery Charger - 5-pin SOT-23."""


# -----------------------------------------------------------------------------
# IO ports
# -----------------------------------------------------------------------------

STAT = io("STAT", Net)
VSS = io("VSS", Net)
VBAT = io("VBAT", Net)
VDD = io("VDD", Net)
PROG = io("PROG", Net)

# -----------------------------------------------------------------------------
# Component definition
# -----------------------------------------------------------------------------

Component(
    name="MCP73831",
    part=builtin.Part(mpn="MCP73831-2-OTI/OT", manufacturer="Microchip"),
    symbol=Symbol(library="@kicad-symbols/Battery_Management.kicad_sym", name="MCP73831-2-OT"),
    footprint=File("@kicad-footprints/Package_TO_SOT_SMD.pretty/SOT-23-5.kicad_mod"),
    prefix="U",
    pin_defs={
        "STAT": "1",
        "VSS": "2",
        "VBAT": "3",
        "VDD": "4",
        "PROG": "5",
    },
    pins={
        "STAT": STAT,
        "VSS": VSS,
        "VBAT": VBAT,
        "VDD": VDD,
        "PROG": PROG,
    },
    properties={
        "value": "MCP73831",
        "package": "SOT-23-5",
    },
)
