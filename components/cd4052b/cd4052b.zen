        "X3": "11",
        "X": "12",
        "X0": "13",
        "X1": "14",
        "X2": "15",
        "VDD": "16",
    },
    pins={
        "Y1": Y1,
        "Y0": Y0,
        "Y": Y,
        "Y2": Y2,
        "Y3": Y3,
        "INH": INH,
        "VEE": VEE,
        "VSS": VSS,
        "B": B,
        "A": A,
        "X3": X3,
        "X": X,
        "X0": X0,
        "X1": X1,
        "X2": X2,
