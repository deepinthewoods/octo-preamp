"""CD4052B Dual 4-Channel Analog Multiplexer - 16-pin SOIC."""


# -----------------------------------------------------------------------------
# IO ports
# -----------------------------------------------------------------------------

# Channel Y
Y0 = io("Y0", Net)
Y1 = io("Y1", Net)
Y2 = io("Y2", Net)
Y3 = io("Y3", Net)
Y = io("Y", Net)

# Channel X
X0 = io("X0", Net)
X1 = io("X1", Net)
X2 = io("X2", Net)
X3 = io("X3", Net)
X = io("X", Net)

# Control
A = io("A", Net)
B = io("B", Net)
INH = io("INH", Net)

# Power
VDD = io("VDD", Net)
VSS = io("VSS", Net)
VEE = io("VEE", Net)

# -----------------------------------------------------------------------------
# Component definition
# -----------------------------------------------------------------------------

Component(
    name="CD4052B",
    part=builtin.Part(mpn="CD4052BM96", manufacturer="Texas Instruments"),
    symbol=Symbol(library="@kicad-symbols/Analog_Switch.kicad_sym", name="CD4052B"),
