GPIO11 = io("GPIO11", Net)
GPIO12 = io("GPIO12", Net)

# -----------------------------------------------------------------------------
# IO ports — Right header (J3, 20 pins)
# -----------------------------------------------------------------------------

GND = io("GND", Net)
