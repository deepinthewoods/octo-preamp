"""
ESP32-S3-DevKitC-1 Header Socket Component

Represents the 2x 20-pin machined female header sockets soldered onto
the PCB, into which the ESP32-S3-DevKitC-1 dev board is inserted.
Pin numbering follows the DevKitC-1 board pinout (viewed from above).
"""


# -----------------------------------------------------------------------------
# IO ports — Left header (J1, 20 pins)
# -----------------------------------------------------------------------------

P_3V3_1 = io("P_3V3_1", Net)
P_3V3_2 = io("P_3V3_2", Net)
RST = io("RST", Net)
GPIO4 = io("GPIO4", Net)
GPIO5 = io("GPIO5", Net)
