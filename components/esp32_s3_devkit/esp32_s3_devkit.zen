GPIO21 = io("GPIO21", Net)
GPIO14 = io("GPIO14", Net)
GPIO13 = io("GPIO13", Net)

# -----------------------------------------------------------------------------
# Component definition — Left header socket (1x20)
# -----------------------------------------------------------------------------

Component(
    name="J_LEFT",
    part=builtin.Part(mpn="PPPC201LFBN-RC", manufacturer="Sullins"),
    symbol=Symbol(library="@kicad-symbols/Connector.kicad_sym", name="Conn_01x20_Socket"),
    footprint=File("@kicad-footprints/Connector_PinSocket_2.54mm.pretty/PinSocket_1x20_P2.54mm_Vertical.kicad_mod"),
